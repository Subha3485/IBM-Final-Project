<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= recipe.title %> - Cookly</title>
    <link rel="stylesheet" href="/css/pages/home.css">
    <link rel="stylesheet" href="/css/shared/index.css">
    <link rel="stylesheet" href="/css/pages/recipe.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <!-- navbar -->
    <nav class="nav">
      <button id="menuToggle" class="menu-toggle" aria-label="Open menu" type="button">
          <i class="fa-solid fa-bars"></i>
      </button>
      <a class="logo header-logo" href="/" aria-label="Go to homepage">
          <img src="/images/Cookly-Icon.svg" alt="Cookly logo">
          <span class="brand-text">Cookly</span>
      </a>
      <div class="top-search-wrap">
          <input id="topSearchInput" class="top-search-input" type="text" placeholder="Search recipes...">
          <button id="topSearchBtn" class="top-search-btn" type="button" aria-label="Search">
              <i class="fa-solid fa-magnifying-glass"></i>
          </button>
          <button id="voiceSearchBtn" class="voice-search-btn" type="button" aria-label="Voice search">
              <i class="fa-solid fa-microphone"></i>
          </button>
      </div>
      <div class="top-actions">
          <a href="/" class="top-pill recipes-pill">Recipes</a>
          <a href="/create" class="top-pill create-pill"><i class="fa-solid fa-plus"></i> Create</a>
          <a href="/login" class="top-pill account-pill"><i class="fa-regular fa-user"></i> Account</a>
          <button id="themeToggle" class="icon-btn theme-btn" type="button" aria-label="Toggle theme">
              <i id="themeIcon" class="fa-regular fa-moon"></i>
          </button>
          <button class="icon-btn bell-btn" type="button" aria-label="Notifications">
              <i class="fa-regular fa-bell"></i>
              <span class="badge">2</span>
          </button>
          <a href="/login" aria-label="Open login page">
              <img class="user-avatar" src="/images/Cookly-Icon.svg" alt="User profile">
          </a>
      </div>
      <ul id="MenuItems">
          <li><a href="/">Home</a></li>
          <li><a href="/">Recipes</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/login">Account Center</a></li>
          <li><a href="/login">Login</a></li>
          <li><a href="/signup">Sign Up</a></li>
          <li><a href="">Cart</a></li>
      </ul>
    </nav>
    <div id="menuBackdrop" class="menu-backdrop"></div>

    <div class="recipe-detail">
        <a href="/" class="back-button">
            <i class="fas fa-arrow-left"></i> Back to Recipes
        </a>
        
        <div class="recipe-header">
            <div class="recipe-image <%= recipe.videoUrl ? 'has-video' : '' %>">
                <% if (recipe.videoUrl) { %>
                    <% const autoplayVideoUrl = recipe.videoUrl.includes('?')
                        ? `${recipe.videoUrl}&autoplay=1&mute=1&playsinline=1&rel=0`
                        : `${recipe.videoUrl}?autoplay=1&mute=1&playsinline=1&rel=0`; %>
                    <iframe
                        src="<%= autoplayVideoUrl %>"
                        title="<%= recipe.title %> video tutorial"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        referrerpolicy="strict-origin-when-cross-origin"
                        allowfullscreen>
                    </iframe>
                <% } else { %>
                    <img src="<%= recipe.image %>" alt="<%= recipe.title %>" onerror="this.src='/images/Cookly-Logo.png'">
                <% } %>
            </div>
            
            <div class="recipe-info">
                <h1><%= recipe.title %></h1>
                <p style="color: #666; font-size: 1.05em; margin: 10px 0;">
                    <i class="fas fa-tag"></i> <%= recipe.cuisineType %>
                </p>
                
                <% if (recipe.description) { %>
                    <div class="description">
                        <%= recipe.description %>
                    </div>
                <% } %>

                <div class="recipe-meta">
                    <div class="meta-item">
                        <i class="fas fa-users"></i>
                        <div class="meta-item-content">
                            <span class="meta-label">Servings</span>
                            <span class="meta-value"><%= recipe.servings %> people</span>
                        </div>
                    </div>

                    <div class="meta-item">
                        <i class="fas fa-clock"></i>
                        <div class="meta-item-content">
                            <span class="meta-label">Prep Time</span>
                            <span class="meta-value"><%= recipe.prepTime %> mins</span>
                        </div>
                    </div>

                    <div class="meta-item">
                        <i class="fas fa-fire"></i>
                        <div class="meta-item-content">
                            <span class="meta-label">Cook Time</span>
                            <span class="meta-value"><%= recipe.cookingTime %> mins</span>
                        </div>
                    </div>

                    <div class="meta-item">
                        <i class="fas fa-utensils"></i>
                        <div class="meta-item-content">
                            <span class="meta-label">Difficulty</span>
                            <span class="meta-value difficulty-<%= recipe.difficulty.toLowerCase() %>">
                                <%= recipe.difficulty %>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="recipe-actions">
                    <button class="like-btn" onclick="toggleLike('<%= recipe.id || recipe._id %>')">
                        <i class="fas fa-heart"></i>
                        <span id="like-text">Like Recipe</span>
                        <span class="like-count" id="like-count"><%= recipe.likes %></span>
                    </button>
                </div>
            </div>
        </div>

        <div class="ingredients">
            <h2><i class="fas fa-list-check"></i> Ingredients</h2>
            <ul>
                <% recipe.ingredients.forEach(ingredient => { %>
                    <li><%= ingredient %></li>
                <% }); %>
            </ul>
        </div>

        <div class="instructions">
            <h2><i class="fas fa-book"></i> Instructions</h2>
            <p><%= recipe.instructions %></p>
        </div>

    </div>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-logo">
                    <h2>Cookly</h2>
                    <p>Delicious recipes at your fingertips!</p>
                </div>
                <div class="footer-links">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="#">Recipes</a></li>
                        <li><a href="/about">About Us</a></li>
                        <li><a href="/contact">Account Center</a></li>
                    </ul>
                </div>
            </div>
            <p class="footer-bottom">&copy; 2025 Cookly. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
        let isLiked = false;
        function getAnonymousLikeKey() {
            const storageKey = 'cookly_like_key';
            let key = localStorage.getItem(storageKey);
            if (!key) {
                key = (window.crypto && crypto.randomUUID)
                    ? crypto.randomUUID()
                    : 'anon-' + Math.random().toString(36).slice(2) + Date.now();
                localStorage.setItem(storageKey, key);
            }
            return key;
        }

        async function toggleLike(recipeId) {
            try {
                const response = await fetch(`/api/recipes/${recipeId}/like`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'x-like-key': getAnonymousLikeKey(),
                    }
                });

                if (!response.ok) {
                    const err = await response.json().catch(() => ({}));
                    throw new Error(err.message || 'Failed to update like');
                }

                const data = await response.json();
                const likeBtn = document.querySelector('.like-btn');
                const likeCount = document.getElementById('like-count');
                const likeText = document.getElementById('like-text');

                likeCount.textContent = data.likes;
                
                if (data.liked) {
                    likeBtn.classList.add('liked');
                    likeText.textContent = 'Liked!';
                } else {
                    likeBtn.classList.remove('liked');
                    likeText.textContent = 'Like Recipe';
                }
            } catch (error) {
                console.error('Error liking recipe:', error);
                alert('Failed to update like. Please try again.');
            }
        }

        // Shared header controls (same behavior as home header).
        const menuToggle = document.getElementById('menuToggle');
        const menuItems = document.getElementById('MenuItems');
        const menuBackdrop = document.getElementById('menuBackdrop');
        const topSearchInput = document.getElementById('topSearchInput');
        const topSearchBtn = document.getElementById('topSearchBtn');
        const voiceSearchBtn = document.getElementById('voiceSearchBtn');
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');

        function closeMenu() {
            menuItems.classList.remove('open');
            menuBackdrop.classList.remove('open');
        }

        menuToggle.addEventListener('click', () => {
            menuItems.classList.toggle('open');
            menuBackdrop.classList.toggle('open');
        });
        menuBackdrop.addEventListener('click', closeMenu);
        menuItems.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));

        function goToSearch(term) {
            const query = (term || '').trim();
            if (!query) {
                window.location.href = '/';
                return;
            }
            window.location.href = '/?q=' + encodeURIComponent(query);
        }

        topSearchBtn.addEventListener('click', () => goToSearch(topSearchInput.value));
        topSearchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                goToSearch(topSearchInput.value);
            }
        });

        voiceSearchBtn.addEventListener('click', function() {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SpeechRecognition) {
                alert('Voice search is not supported in this browser.');
                return;
            }
            const recognition = new SpeechRecognition();
            recognition.lang = 'en-US';
            recognition.onresult = function(event) {
                const text = event.results[0][0].transcript || '';
                topSearchInput.value = text;
                goToSearch(text);
            };
            recognition.start();
        });

        function applyTheme(theme) {
            document.body.classList.toggle('theme-dark', theme === 'dark');
            themeIcon.className = theme === 'dark' ? 'fa-regular fa-sun' : 'fa-regular fa-moon';
        }
        const savedTheme = localStorage.getItem('cooklyTheme');
        applyTheme(savedTheme === 'dark' ? 'dark' : 'light');
        themeToggle.addEventListener('click', function() {
            const nextTheme = document.body.classList.contains('theme-dark') ? 'light' : 'dark';
            applyTheme(nextTheme);
            localStorage.setItem('cooklyTheme', nextTheme);
        });
    </script>
</body>
</html>
