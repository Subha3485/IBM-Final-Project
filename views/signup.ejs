<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Cookly</title>
    <link rel="stylesheet" href="/css/pages/signup.css">
</head>
<body>
    <div class="container">
        <div class="image-section">
            <img src="https://images.unsplash.com/photo-1495521821757-a1efb6729352?auto=format&fit=crop&w=1400&q=80" alt="Fresh plated recipe ingredients">
            <div class="image-overlay">
                <div class="visual-chip">Discover. Cook. Share.</div>
                <h2>Start your own recipe collection with Cookly.</h2>
                <p>Save favorites, publish original recipes, and keep your cooking inspiration organized in one place.</p>
            </div>
        </div>
        <div class="form-section">
            <a class="logo" href="/" aria-label="Go to homepage">
                <img src="/images/Cookly-Logo.svg" alt="Cookly logo">
            </a>

            <p class="eyebrow">Join Cookly</p>
            <h1>Create your account</h1>
            <p class="subtitle">Sign up with your details below. After signup, you will be logged in automatically.</p>

            <form id="signupForm" class="auth-form">
                <label class="field-label" for="name">Full name</label>
                <input id="name" name="name" type="text" placeholder="Your name" required>

                <label class="field-label" for="email">Email</label>
                <input id="email" name="email" type="email" placeholder="you@example.com" required>

                <label class="field-label" for="password">Password</label>
                <input id="password" name="password" type="password" placeholder="Create password" required>

                <label class="field-label" for="confirmPassword">Confirm password</label>
                <input id="confirmPassword" name="confirmPassword" type="password" placeholder="Repeat password" required>

                <button type="submit" class="primary-button">Create Account</button>
                <p id="signupMessage" class="form-message" aria-live="polite"></p>
            </form>

            <div class="divider"><span>or continue with</span></div>

            <ul class="social-providers">
                <li>
                    <a class="signup-button google-signup" href="/auth/google">
                        <img src="https://cdn-icons-png.freepik.com/256/2504/2504739.png?ga=GA1.1.1730312580.1740674040&semt=ais_hybrid" alt="Google Icon">Continue with Google
                    </a>
                </li>
                <li>
                    <a class="signup-button facebook-signup" href="/auth/facebook">
                        <img src="https://cdn-icons-png.freepik.com/256/15047/15047435.png?ga=GA1.1.1730312580.1740674040&semt=ais_hybrid" alt="Facebook Icon">Continue with Facebook
                    </a>
                </li>
            </ul>

            <p class="login-link">Already have an account? <a href="/login">Log in</a></p>
        </div>
    </div>

    <script>
        const signupForm = document.getElementById('signupForm');
        const signupMessage = document.getElementById('signupMessage');

        signupForm.addEventListener('submit', async (event) => {
            event.preventDefault();
            signupMessage.textContent = 'Creating account...';
            signupMessage.className = 'form-message';

            const name = signupForm.name.value.trim();
            const email = signupForm.email.value.trim();
            const password = signupForm.password.value;
            const confirmPassword = signupForm.confirmPassword.value;

            if (password !== confirmPassword) {
                signupMessage.textContent = 'Passwords do not match.';
                signupMessage.className = 'form-message error';
                return;
            }

            try {
                const registerResponse = await fetch('/api/users/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, email, password })
                });

                const registerData = await registerResponse.json();
                if (!registerResponse.ok) {
                    throw new Error(registerData.error || 'Signup failed');
                }

                const loginResponse = await fetch('/api/users/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                const loginData = await loginResponse.json();
                if (!loginResponse.ok) {
                    throw new Error(loginData.error || 'Account created, but login failed');
                }

                if (loginData.token) {
                    localStorage.setItem('cooklyToken', loginData.token);
                }

                signupMessage.textContent = 'Account created successfully. Redirecting...';
                signupMessage.className = 'form-message success';
                window.setTimeout(() => {
                    window.location.href = '/';
                }, 700);
            } catch (error) {
                signupMessage.textContent = error.message;
                signupMessage.className = 'form-message error';
            }
        });
    </script>
</body>
</html>
